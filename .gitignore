# =============================================================
# .gitignore — MyEnglishBooks MIS
# =============================================================

# ── Secrets — NEVER commit these ─────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.example
*.pem
*.key

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── pytest / coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# ── Generated report files ────────────────────────────────────
/tmp/mis_reports/
*.pdf
*.xlsx

# ── IDE ───────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

